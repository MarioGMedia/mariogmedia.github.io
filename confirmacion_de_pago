<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gracias — MarioG Media</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@300;400;500;600;700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #09100a;
      --accent: #22c55e;
      --accent-dim: rgba(34,197,94,0.12);
      --white: #f5f5f0;
      --white-muted: rgba(245,245,240,0.55);
      --white-faint: rgba(245,245,240,0.1);
    }

    html, body { height: 100%; background: var(--bg); color: var(--white); font-family: 'Barlow', sans-serif; overflow: hidden; }

    body::before {
      content: ''; position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      background-size: 200px 200px; pointer-events: none; z-index: 0; opacity: 0.6;
    }
    body::after {
      content: ''; position: fixed; top: -120px; left: 50%; transform: translateX(-50%);
      width: 700px; height: 400px;
      background: radial-gradient(ellipse at center, rgba(34,197,94,0.09) 0%, transparent 70%);
      pointer-events: none; z-index: 0;
    }

    .page {
      position: relative; z-index: 1; height: 100vh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 2rem 1.5rem; text-align: center;
    }

    .wordmark {
      position: fixed; top: 2rem; left: 0; right: 0; text-align: center;
      font-family: 'Barlow Condensed', sans-serif; font-weight: 600; font-size: 0.88rem;
      letter-spacing: 0.25em; text-transform: uppercase; color: var(--white);
      opacity: 0; animation: fadeUp 0.6s ease forwards 0.1s;
    }
    .wordmark .dot { color: var(--accent); }

    .check-wrap { margin-bottom: 2rem; opacity: 0; animation: scaleIn 0.5s cubic-bezier(0.34,1.56,0.64,1) forwards 0.3s; }
    .check-circle {
      width: 68px; height: 68px; border-radius: 50%;
      background: var(--accent-dim); border: 1.5px solid rgba(34,197,94,0.35);
      display: flex; align-items: center; justify-content: center; position: relative;
    }
    .check-circle::after { content: ''; position: absolute; inset: -6px; border-radius: 50%; border: 1px solid rgba(34,197,94,0.12); }
    .check-circle svg { width: 28px; height: 28px; stroke: var(--accent); stroke-width: 2.5; fill: none; stroke-linecap: round; stroke-linejoin: round; }

    .eyebrow {
      font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; font-weight: 500;
      letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent);
      margin-bottom: 1.1rem; opacity: 0; animation: fadeUp 0.6s ease forwards 0.45s;
    }

    h1 {
      font-family: 'Anton', sans-serif; font-size: clamp(2.8rem, 8vw, 5.5rem);
      line-height: 0.95; letter-spacing: 0.01em; text-transform: uppercase;
      color: var(--white); max-width: 680px; margin-bottom: 0.2em;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.55s;
    }
    h1 .accent { color: var(--accent); display: block; }

    .divider { width: 40px; height: 1px; background: rgba(34,197,94,0.3); margin: 0 auto 1.4rem; opacity: 0; animation: fadeUp 0.5s ease forwards 0.65s; }

    .sub {
      font-family: 'Barlow', sans-serif; font-size: clamp(0.95rem, 2.5vw, 1.05rem);
      font-weight: 300; color: var(--white-muted); line-height: 1.6; max-width: 420px;
      margin-top: 1.4rem; margin-bottom: 2.6rem;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.7s;
    }

    .ctas {
      display: flex; flex-direction: column; gap: 0.85rem;
      width: 100%; max-width: 340px;
      opacity: 0; animation: fadeUp 0.7s ease forwards 0.85s;
    }

    .btn {
      display: flex; align-items: center; justify-content: center; gap: 0.6rem;
      padding: 0.95rem 1.5rem; border-radius: 3px;
      font-family: 'Barlow Condensed', sans-serif; font-size: 0.95rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
      cursor: pointer; transition: transform 0.18s ease, box-shadow 0.18s ease;
      position: relative; overflow: hidden;
    }
    .btn::before { content: ''; position: absolute; inset: 0; background: rgba(255,255,255,0.04); opacity: 0; transition: opacity 0.18s ease; }
    .btn:hover::before { opacity: 1; }
    .btn:hover { transform: translateY(-2px); }
    .btn:active { transform: translateY(0); }
    .btn svg { width: 16px; height: 16px; flex-shrink: 0; }

    .btn-wa { background: var(--accent); color: #07180b; box-shadow: 0 0 24px rgba(34,197,94,0.2); }
    .btn-wa:hover { box-shadow: 0 6px 32px rgba(34,197,94,0.35); }

    .btn-cal { background: transparent; color: var(--white); border: 1px solid rgba(245,245,240,0.18); }
    .btn-cal:hover { border-color: rgba(245,245,240,0.4); box-shadow: 0 4px 20px rgba(0,0,0,0.3); }

    .footer-note {
      position: fixed; bottom: 1.8rem; left: 50%; transform: translateX(-50%);
      font-family: 'Barlow Condensed', sans-serif; font-size: 0.68rem;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--white-faint);
      white-space: nowrap; opacity: 0; animation: fadeUp 0.5s ease forwards 1.1s;
    }

    @keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
    @keyframes scaleIn { from { opacity:0; transform:scale(0.6); } to { opacity:1; transform:scale(1); } }

    @media (max-height: 680px) {
      .check-wrap { margin-bottom: 1.2rem; }
      .check-circle { width: 54px; height: 54px; }
      h1 { font-size: clamp(2.2rem, 10vw, 3.5rem); }
      .sub { margin-top: 1rem; margin-bottom: 1.8rem; }
    }
  </style>
</head>
<body>

  <span class="wordmark">MarioG<span class="dot">.</span> Media</span>

